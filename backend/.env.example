# ===================================
# BACKEND PRINCIPAL - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ===================================

# ----------------------------------
# APLICACIÓN
# ----------------------------------
BACKEND_ENVIRONMENT=development
BACKEND_LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# ----------------------------------
# EMBEDDING SERVICE
# ----------------------------------
BACKEND_EMBEDDING_SERVICE_HOST=localhost
BACKEND_EMBEDDING_SERVICE_HTTP_PORT=8001
BACKEND_EMBEDDING_SERVICE_GRPC_PORT=50051
BACKEND_EMBEDDING_SERVICE_TIMEOUT=30
BACKEND_EMBEDDING_DIMENSION=384

# ----------------------------------
# REDIS
# ----------------------------------
BACKEND_REDIS_HOST=localhost
BACKEND_REDIS_PORT=6379
BACKEND_REDIS_DB=0
# BACKEND_REDIS_PASSWORD=tu_password_aqui
BACKEND_REDIS_TIMEOUT=5
BACKEND_REDIS_CACHE_TTL=3600

# ----------------------------------
# CELERY
# ----------------------------------
BACKEND_CELERY_BROKER_URL=redis://localhost:6379/0
BACKEND_CELERY_RESULT_BACKEND=redis://localhost:6379/1
BACKEND_CELERY_TASK_TIMEOUT=300

# ----------------------------------
# OLLAMA
# ----------------------------------
BACKEND_OLLAMA_HOST=localhost
BACKEND_OLLAMA_PORT=11434
BACKEND_OLLAMA_MODEL=llama3.2:3b
BACKEND_OLLAMA_TIMEOUT=300
BACKEND_OLLAMA_MAX_TOKENS=512
BACKEND_OLLAMA_TEMPERATURE=0.1

# ----------------------------------
# BÚSQUEDA HÍBRIDA
# ----------------------------------
BACKEND_BM25_TOP_K=10
BACKEND_VECTOR_TOP_K=10
BACKEND_RRF_K=60
BACKEND_HYBRID_TOP_K=5

# ----------------------------------
# CHROMADB
# ----------------------------------
BACKEND_CHROMA_HOST=localhost
BACKEND_CHROMA_PORT=8002
BACKEND_CHROMA_COLLECTION_NAME=qa_collection
BACKEND_CHROMA_PERSIST_DIR=./chroma_data

# ----------------------------------
# CIRCUIT BREAKER
# ----------------------------------
BACKEND_CB_FAIL_MAX=5
BACKEND_CB_RESET_TIMEOUT=60

# ----------------------------------
# CACHE LOCAL
# ----------------------------------
BACKEND_CACHE_MAX_SIZE=500
BACKEND_CACHE_TTL=1800